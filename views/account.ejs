<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Settings</title>
    <link rel="stylesheet" href="/styles/styles.css">
</head>
<body>
    <h1>Sign Up For An Account</h1>
    <form action="/account" method="POST">
        <input class="accountForm" name="user_id" type="text" placeholder="Username"><br>
        <input class="accountForm" name="password" type="password" placeholder="Password"><br>

        <input class="accountForm" name="newName" type="text" value="<%= name %>"><br>
        <input class="accountForm" name="newUserID" type="text" placeholder="New Username"><br>
        <input class="accountForm" name="newPassword" type="password" placeholder="New Password"><br>
        <input class="accountForm" type="submit" value="Change Account Details">
    </form>
    <% if( locals.err ){ %>
        <p>Error: Username/Password Does Not Match Existing User!</p>
    <% } %>
</body>
</html>